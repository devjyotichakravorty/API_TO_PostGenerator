        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response time is below 1000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Response contains id\", function () {",
              "    pm.expect(jsonData).to.have.property(\"id\");",
              "});",
              "",
              "pm.test(\"Response contains name\", function () {",
              "    pm.expect(jsonData).to.have.property(\"name\");",
              "});",
              "",
              "pm.test(\"Response contains email\", function () {",
              "    pm.expect(jsonData).to.have.property(\"email\");",
              "});",
              "",
              "pm.test(\"id is exact value 1\", function () {",
              "    pm.expect(jsonData.id).to.eql(1);",
              "});",
              "",
              "pm.test(\"email is valid format\", function () {",
              "    pm.expect(jsonData.email).to.match(/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/);",
              "});",
              "",
              "pm.test(\"name is valid string\", function () {",
              "    pm.expect(jsonData.name).to.be.a('string');",
              "    pm.expect(jsonData.name).to.have.lengthOf.at.least(1);",
              "});"
